# Puerto del backend
PORT=5001

# Entorno
NODE_ENV=development

# Orígenes permitidos por CORS (separados por coma, sin espacios).
# Incluye el frontend tpc-main en dev + los dominios de producción.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://carhub365.es,https://www.carhub365.es

# URL pública del frontend (para success_url / cancel_url / portal return_url)
FRONTEND_URL=http://localhost:3000

# =======================================================
# 💳 STRIPE — Suscripción
# =======================================================
# Clave secreta. EMPIEZA CON sk_test_ PARA PRUEBAS.
# No subas la clave live (sk_live_) al repo bajo ningún concepto.
STRIPE_SECRET_KEY=sk_test_xxx

# ID del precio del plan único (se crea en Stripe Dashboard → Products).
# Formato: price_1Nxxxxx...
STRIPE_PRICE_ID=price_xxx

# Secreto para verificar webhooks. Se obtiene al crear el endpoint en
# Stripe → Developers → Webhooks. Formato: whsec_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# =======================================================
# 🔐 Shared secret server-to-server
# =======================================================
# Lo usa tpc-main para consultar POST /api/billing/access/check
# Genera uno largo y aleatorio: `openssl rand -hex 32`
BILLING_ACCESS_SECRET=

# =======================================================
# 🗄️ Supabase — persistencia de billing_access
# =======================================================
# URL del proyecto Supabase (la misma que usa tpc-main). Ej:
#   https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# SERVICE_ROLE key (NO la anon). Se requiere porque la tabla
# public.billing_access tiene RLS activo sin policies — solo el
# service role puede leer/escribir. NUNCA expongas esta clave en
# el frontend ni la subas al repo.
SUPABASE_SERVICE_ROLE_KEY=

# Secreto para firmar tokens internos (si se activa auth propia)
# JWT_SECRET=cambia-esto-en-produccion

# =======================================================
# 📧 Resend — email de bienvenida con credenciales
# =======================================================
# Tras pagar, el webhook crea el usuario en Supabase Auth con una
# contraseña aleatoria y se la envía al comprador por email.
# Requiere cuenta en https://resend.com (100 emails/día gratis).
#
# API key (empieza por re_). Créala en Resend → API Keys.
RESEND_API_KEY=

# Remitente. Durante pruebas puedes usar 'onboarding@resend.dev', pero
# SOLO llega a la propia cuenta del dueño de la API key. Para envío
# real, verifica un dominio en Resend → Domains y usa algo como:
#   'Broker de Coches <no-reply@brokerdecoches.com>'
RESEND_FROM=onboarding@resend.dev
