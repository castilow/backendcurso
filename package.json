{
  "name": "backendcursos",
  "version": "0.1.0",
  "private": true,
  "description": "Backend de cursos para conectar con tpc-main (carhub365)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "setup:stripe": "tsx scripts/setupStripe.ts",
    "lint": "echo \"(sin lint configurado)\" && exit 0"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "stripe": "^17.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.12",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
